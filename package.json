{
  "name": "wedding-photos",
  "version": "1.0.0",
  "description": "QR-code photo sharing for John & Kate's wedding — guests scan their table's code and upload photos, permanently stored in Cloudflare R2",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "STORAGE_DRIVER=local node server.js",
    "qr": "node scripts/generate-qr.js",
    "test": "node --test --test-concurrency=1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "archiver": "^7.0.1",
    "express": "^4.21.2",
    "heic-convert": "^2.1.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5"
  }
}
